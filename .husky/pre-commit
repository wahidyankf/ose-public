# 1. Validate .claude/ and .opencode/ config (if affected)
if git diff --cached --name-only | grep -qE '^\.claude/|^\.opencode/'; then
  echo "🔍 Validating .claude/ and .opencode/ configuration..."
  npm run validate:config || {
    echo "❌ Configuration validation failed. Fix errors above before committing."
    exit 1
  }
  echo "✅ Configuration validation passed"
else
  echo "⏭️  Skipping config validation (no .claude/ or .opencode/ changes in staged files)"
fi

# 2. Validate docker-compose.yml files (if affected)
if git diff --cached --name-only | grep -qE 'docker-compose\.ya?ml$'; then
  echo "🔍 Validating docker-compose.yml files..."

  # Find all staged docker-compose files
  for compose_file in $(git diff --cached --name-only | grep -E 'docker-compose\.ya?ml$'); do
    if [ -f "$compose_file" ]; then
      echo "  Checking $compose_file..."

      # Validate YAML syntax and docker-compose config
      if ! docker compose -f "$compose_file" config > /dev/null 2>&1; then
        echo "❌ Docker Compose validation failed for $compose_file"
        echo "   Run: docker compose -f $compose_file config"
        exit 1
      fi

      echo "  ✅ $compose_file is valid"
    fi
  done

  echo "✅ All docker-compose files validated"
else
  echo "⏭️  Skipping docker-compose validation (no docker-compose.yml changes in staged files)"
fi

# 3. Run ayokoding-web pre-commit scripts if affected (titles update + nav regen)
nx affected -t run-pre-commit --skip-nx-cache 2>/dev/null || echo "⚠️  Skipping run-pre-commit (not affected or binary missing)"

# 4. Stage any changes made by the scripts
git add apps/ayokoding-web/content/ 2>/dev/null || true

# 5. Run lint-staged for formatting
npx lint-staged

# 6. Auto-format staged Elixir files (mix format per project)
staged_elixir=$(git diff --cached --name-only | grep -E '\.(ex|exs)$' | grep -vE '/(deps|_build)/' || true)
if [ -n "$staged_elixir" ]; then
  if ! command -v mix >/dev/null 2>&1; then
    echo "⚠️  mix not found, skipping Elixir formatting"
  else
    echo "🔧 Formatting Elixir files..."
    # Collect unique Mix project roots
    project_roots=""
    for file in $staged_elixir; do
      dir=$(dirname "$file")
      while [ "$dir" != "." ] && [ ! -f "$dir/mix.exs" ]; do
        dir=$(dirname "$dir")
      done
      if [ -f "$dir/mix.exs" ]; then
        case " $project_roots " in
          *" $dir "*) ;;
          *) project_roots="$project_roots $dir" ;;
        esac
      fi
    done
    # Run mix format per project with its relevant files
    for project_dir in $project_roots; do
      project_files=""
      for file in $staged_elixir; do
        case "$file" in
          "$project_dir/"*) project_files="$project_files ${file#${project_dir}/}" ;;
        esac
      done
      if [ -n "$project_files" ]; then
        (cd "$project_dir" && mix format $project_files)
      fi
    done
    git add $staged_elixir
    echo "✅ Elixir files formatted"
  fi
else
  echo "⏭️  Skipping Elixir formatting (no .ex/.exs files staged)"
fi

# 7. Validate and auto-fix docs file naming conventions (if docs/ affected)
if git diff --cached --name-only | grep -qE '^docs/'; then
  echo "🔍 Validating and fixing documentation file naming..."
  CGO_ENABLED=0 go run -C apps/rhino-cli main.go docs validate-naming --staged-only --fix --apply || exit 1
  # Stage any files modified by link updates and renames
  git add docs/ governance/ .claude/ 2>/dev/null || true
  echo "✅ Documentation naming validation passed"
else
  echo "⏭️  Skipping docs naming validation (no docs/ changes in staged files)"
fi

# 8. Validate markdown links in staged files
CGO_ENABLED=0 go run -C apps/rhino-cli main.go docs validate-links --staged-only || exit 1

# 9. Validate all markdown files
npm run lint:md || exit 1
