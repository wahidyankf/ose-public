{
  "$schema": "https://opencode.ai/config.json",
  "model": "zai-coding-plan/glm-5.1",
  "small_model": "zai-coding-plan/glm-5-turbo",
  "permission": {
    "read": "allow",
    "edit": {
      "*": "ask",
      ".claude/**": "allow",
      ".opencode/**": "allow"
    },
    "bash": {
      "*": "ask",
      "npm run sync*": "allow",
      "git *": "allow",
      "nx *": "allow",
      "npx *": "ask",
      "go *": "allow",
      "gofmt *": "allow",
      "rm -rf *": "deny"
    },
    "glob": "allow",
    "grep": "allow",
    "list": "allow",
    "skill": "allow",
    "external_directory": {
      "/tmp/**": "allow"
    }
  },
  "mcp": {
    "zai-mcp-server": {
      "type": "local",
      "command": ["npx", "-y", "@z_ai/mcp-server"]
    },
    "web-search-prime": {
      "type": "remote",
      "url": "https://api.z.ai/api/mcp/web_search_prime/mcp"
    },
    "web-reader": {
      "type": "remote",
      "url": "https://api.z.ai/api/mcp/web_reader/mcp"
    },
    "zread": {
      "type": "remote",
      "url": "https://api.z.ai/api/mcp/zread/mcp"
    },
    "perplexity": {
      "type": "local",
      "command": ["npx", "-y", "@perplexity-ai/mcp-server"]
    },
    "nx-mcp": {
      "type": "local",
      "command": ["npx", "-y", "nx-mcp"],
      "enabled": true
    },
    "playwright": {
      "type": "local",
      "command": ["npx", "-y", "@playwright/mcp@latest"]
    }
  }
}
