{
  "name": "a-demo-be-e2e",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "apps/a-demo-be-e2e/tests",
  "targets": {
    "install": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npm install",
        "cwd": "apps/a-demo-be-e2e"
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx oxlint@latest .",
        "cwd": "apps/a-demo-be-e2e"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx bddgen && npx tsc --noEmit",
        "cwd": "apps/a-demo-be-e2e"
      },
      "inputs": ["default", "{workspaceRoot}/specs/apps/a-demo/be/gherkin/**/*.feature"]
    },
    "test:quick": {
      "executor": "nx:run-commands",
      "options": {
        "commands": ["npx oxlint@latest .", "npx bddgen && npx tsc --noEmit"],
        "parallel": true,
        "cwd": "apps/a-demo-be-e2e"
      },
      "inputs": ["default", "{workspaceRoot}/specs/apps/a-demo/be/gherkin/**/*.feature"]
    },
    "test:e2e": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx bddgen && npx playwright test",
        "cwd": "apps/a-demo-be-e2e"
      }
    },
    "test:e2e:no-test-api": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx bddgen && npx playwright test --grep-invert 'Test Support API'",
        "cwd": "apps/a-demo-be-e2e"
      }
    },
    "test:e2e:shard": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx bddgen && npx playwright test --shard=${SHARD}",
        "cwd": "apps/a-demo-be-e2e"
      }
    },
    "test:e2e:ui": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx bddgen && npx playwright test --ui",
        "cwd": "apps/a-demo-be-e2e"
      }
    },
    "test:e2e:report": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx playwright show-report",
        "cwd": "apps/a-demo-be-e2e"
      }
    },
    "spec-coverage": {
      "command": "CGO_ENABLED=0 go run -C apps/rhino-cli main.go spec-coverage validate specs/apps/a-demo/be/gherkin apps/a-demo-be-e2e",
      "cache": true,
      "inputs": ["{workspaceRoot}/specs/apps/a-demo/be/gherkin/**/*.feature", "{projectRoot}/**/*.ts"]
    }
  },
  "tags": ["type:e2e", "platform:playwright", "lang:ts", "domain:a-demo-be"],
  "implicitDependencies": [
    "a-demo-be-java-springboot",
    "a-demo-be-elixir-phoenix",
    "a-demo-be-fsharp-giraffe",
    "a-demo-be-golang-gin",
    "a-demo-be-python-fastapi",
    "a-demo-be-rust-axum",
    "a-demo-be-kotlin-ktor",
    "a-demo-be-java-vertx",
    "a-demo-be-ts-effect",
    "a-demo-be-csharp-aspnetcore",
    "a-demo-be-clojure-pedestal",
    "a-demo-contracts"
  ]
}
