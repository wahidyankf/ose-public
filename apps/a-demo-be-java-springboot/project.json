{
  "name": "a-demo-be-java-springboot",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/a-demo-be-java-springboot/src",
  "projectType": "application",
  "targets": {
    "codegen": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx openapi-generator-cli generate -i $(pwd)/specs/apps/a-demo/contracts/generated/openapi-bundled.yaml -g java -o $(pwd)/apps/a-demo-be-java-springboot/generated-contracts --model-package com.ademobejasb.contracts --additional-properties=library=resttemplate,dateLibrary=java8,openApiNullable=false,useBeanValidation=false,serializationLibrary=jackson --global-property=models,modelDocs=false,apiDocs=false && (WS_ROOT=$(pwd) && cd $(pwd)/apps/rhino-cli && CGO_ENABLED=0 go run main.go contracts java-clean-imports $WS_ROOT/apps/a-demo-be-java-springboot/generated-contracts)"
      },
      "dependsOn": ["a-demo-contracts:bundle"],
      "cache": true,
      "inputs": [
        "{workspaceRoot}/specs/apps/a-demo/contracts/generated/openapi-bundled.yaml",
        "{workspaceRoot}/apps/rhino-cli/cmd/**/*.go",
        "{workspaceRoot}/apps/rhino-cli/internal/**/*.go"
      ],
      "outputs": ["{projectRoot}/generated-contracts"]
    },
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "mvn clean package -DskipTests",
        "cwd": "apps/a-demo-be-java-springboot"
      },
      "outputs": ["{projectRoot}/target"],
      "dependsOn": ["codegen"]
    },
    "dev": {
      "executor": "nx:run-commands",
      "options": {
        "command": "mvn spring-boot:run -Dspring-boot.run.profiles=dev",
        "cwd": "apps/a-demo-be-java-springboot"
      }
    },
    "start": {
      "executor": "nx:run-commands",
      "options": {
        "command": "sh -c 'java -jar target/a-demo-be-java-springboot-*.jar'",
        "cwd": "apps/a-demo-be-java-springboot"
      }
    },
    "test:quick": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          "mvn test",
          "(cd ../../apps/rhino-cli && CGO_ENABLED=0 go run main.go test-coverage validate apps/a-demo-be-java-springboot/target/site/jacoco/jacoco.xml 90)"
        ],
        "parallel": false,
        "cwd": "apps/a-demo-be-java-springboot"
      },
      "cache": true,
      "inputs": [
        "{projectRoot}/src/**",
        "{projectRoot}/pom.xml",
        "{projectRoot}/generated-contracts/**/*",
        "{workspaceRoot}/specs/apps/a-demo/be/gherkin/**/*.feature"
      ],
      "outputs": ["{projectRoot}/target/site/jacoco/jacoco.xml"]
    },
    "test:unit": {
      "executor": "nx:run-commands",
      "options": {
        "command": "mvn test",
        "cwd": "apps/a-demo-be-java-springboot"
      },
      "cache": true,
      "inputs": [
        "{projectRoot}/src/**",
        "{projectRoot}/pom.xml",
        "{projectRoot}/generated-contracts/**/*",
        "{workspaceRoot}/specs/apps/a-demo/be/gherkin/**/*.feature"
      ]
    },
    "test:integration": {
      "executor": "nx:run-commands",
      "options": {
        "command": "docker compose -f docker-compose.integration.yml down -v && docker compose -f docker-compose.integration.yml up --abort-on-container-exit --build",
        "cwd": "apps/a-demo-be-java-springboot"
      },
      "cache": false
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "commands": ["mvn checkstyle:check", "mvn pmd:check"],
        "parallel": false,
        "cwd": "apps/a-demo-be-java-springboot"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          "nx run rhino-cli:build --skip-nx-cache && ./apps/rhino-cli/dist/rhino-cli java validate-annotations apps/a-demo-be-java-springboot/src/main/java",
          "cd apps/a-demo-be-java-springboot && mvn compile -Pnullcheck"
        ],
        "parallel": false
      },
      "dependsOn": ["codegen"],
      "cache": true
    },
    "spec-coverage": {
      "command": "CGO_ENABLED=0 go run -C apps/rhino-cli main.go spec-coverage validate specs/apps/a-demo/be/gherkin apps/a-demo-be-java-springboot",
      "cache": true,
      "inputs": ["{workspaceRoot}/specs/apps/a-demo/be/gherkin/**/*.feature", "{projectRoot}/**/*.java"]
    }
  },
  "tags": ["type:app", "platform:spring-boot", "lang:java", "domain:a-demo-be"],
  "implicitDependencies": ["a-demo-contracts", "rhino-cli"]
}
