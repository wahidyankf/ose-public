{
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "name": "a-demo-fe-e2e",
  "sourceRoot": "apps/a-demo-fe-e2e/tests",
  "projectType": "application",
  "targets": {
    "install": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx playwright install --with-deps chromium",
        "cwd": "{projectRoot}"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc --noEmit",
        "cwd": "{projectRoot}"
      },
      "inputs": ["default", "{workspaceRoot}/specs/apps/a-demo/fe/gherkin/**/*.feature"]
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx oxlint@latest .",
        "cwd": "{projectRoot}"
      }
    },
    "test:quick": {
      "executor": "nx:run-commands",
      "options": {
        "commands": ["tsc --noEmit", "npx oxlint@latest ."],
        "parallel": true,
        "cwd": "{projectRoot}"
      },
      "inputs": ["default", "{workspaceRoot}/specs/apps/a-demo/fe/gherkin/**/*.feature"]
    },
    "test:e2e": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx bddgen && npx playwright test",
        "cwd": "{projectRoot}"
      }
    },
    "test:e2e:shard": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx bddgen && npx playwright test --shard=${SHARD}",
        "cwd": "{projectRoot}"
      }
    },
    "test:e2e:ui": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx bddgen && npx playwright test --ui",
        "cwd": "{projectRoot}"
      }
    },
    "test:e2e:report": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx playwright show-report",
        "cwd": "{projectRoot}"
      }
    },
    "spec-coverage": {
      "command": "CGO_ENABLED=0 go run -C apps/rhino-cli main.go spec-coverage validate specs/apps/a-demo/fe/gherkin apps/a-demo-fe-e2e",
      "cache": true,
      "inputs": ["{workspaceRoot}/specs/apps/a-demo/fe/gherkin/**/*.feature", "{projectRoot}/**/*.ts"]
    }
  },
  "tags": ["type:e2e", "platform:playwright", "lang:ts", "domain:a-demo-fe"],
  "implicitDependencies": [
    "a-demo-fe-ts-nextjs",
    "a-demo-fe-dart-flutterweb",
    "a-demo-fe-ts-tanstack-start",
    "a-demo-contracts"
  ]
}
