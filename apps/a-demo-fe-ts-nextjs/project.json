{
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "name": "a-demo-fe-ts-nextjs",
  "sourceRoot": "apps/a-demo-fe-ts-nextjs/src",
  "projectType": "application",
  "targets": {
    "codegen": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx @hey-api/openapi-ts -i specs/apps/a-demo/contracts/generated/openapi-bundled.yaml -o apps/a-demo-fe-ts-nextjs/src/generated-contracts -s"
      },
      "dependsOn": ["a-demo-contracts:bundle"],
      "cache": true,
      "inputs": ["{workspaceRoot}/specs/apps/a-demo/contracts/generated/openapi-bundled.yaml"],
      "outputs": ["{projectRoot}/src/generated-contracts"]
    },
    "dev": {
      "executor": "nx:run-commands",
      "options": {
        "command": "next dev --port 3301",
        "cwd": "{projectRoot}"
      }
    },
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "next build",
        "cwd": "{projectRoot}"
      },
      "outputs": ["{projectRoot}/.next"],
      "dependsOn": []
    },
    "start": {
      "executor": "nx:run-commands",
      "options": {
        "command": "next start --port 3301",
        "cwd": "{projectRoot}"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc --noEmit",
        "cwd": "{projectRoot}"
      },
      "dependsOn": ["codegen"]
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx oxlint@latest --jsx-a11y-plugin .",
        "cwd": "{projectRoot}"
      },
      "inputs": ["{projectRoot}/src/**/*", "{projectRoot}/oxlint.json", "{projectRoot}/tsconfig.json"]
    },
    "test:quick": {
      "executor": "nx:run-commands",
      "cache": true,
      "inputs": [
        "default",
        "{projectRoot}/src/generated-contracts/**/*",
        "{workspaceRoot}/specs/apps/a-demo/fe/gherkin/**/*.feature"
      ],
      "outputs": ["{projectRoot}/coverage"],
      "options": {
        "command": "npx vitest run --coverage && (cd ../../apps/rhino-cli && CGO_ENABLED=0 go run main.go test-coverage validate apps/a-demo-fe-ts-nextjs/coverage/lcov.info 70)",
        "cwd": "{projectRoot}"
      }
    },
    "test:unit": {
      "executor": "nx:run-commands",
      "cache": true,
      "inputs": [
        "default",
        "{projectRoot}/src/generated-contracts/**/*",
        "{workspaceRoot}/specs/apps/a-demo/fe/gherkin/**/*.feature"
      ],
      "options": {
        "command": "npx vitest run --project unit",
        "cwd": "{projectRoot}"
      },
      "dependsOn": ["codegen"]
    },
    "spec-coverage": {
      "command": "CGO_ENABLED=0 go run -C apps/rhino-cli main.go spec-coverage validate --shared-steps --exclude-dir test-support specs/apps/a-demo/fe/gherkin apps/a-demo-fe-ts-nextjs",
      "cache": true,
      "inputs": ["{workspaceRoot}/specs/apps/a-demo/fe/gherkin/**/*.feature", "{projectRoot}/**/*.{ts,tsx}"]
    }
  },
  "tags": ["type:app", "platform:nextjs", "lang:ts", "domain:a-demo-fe"],
  "implicitDependencies": ["a-demo-contracts", "rhino-cli"]
}
