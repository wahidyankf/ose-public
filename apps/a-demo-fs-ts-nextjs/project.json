{
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "name": "a-demo-fs-ts-nextjs",
  "sourceRoot": "apps/a-demo-fs-ts-nextjs/src",
  "projectType": "application",
  "targets": {
    "codegen": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx @hey-api/openapi-ts -i specs/apps/a-demo/contracts/generated/openapi-bundled.yaml -o apps/a-demo-fs-ts-nextjs/src/generated-contracts -s"
      },
      "dependsOn": ["a-demo-contracts:bundle"],
      "cache": true,
      "inputs": ["{workspaceRoot}/specs/apps/a-demo/contracts/generated/openapi-bundled.yaml"],
      "outputs": ["{projectRoot}/src/generated-contracts"]
    },
    "dev": {
      "executor": "nx:run-commands",
      "options": {
        "command": "next dev --port 3401",
        "cwd": "{projectRoot}"
      }
    },
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "next build",
        "cwd": "{projectRoot}"
      },
      "outputs": ["{projectRoot}/.next"],
      "dependsOn": ["codegen"]
    },
    "start": {
      "executor": "nx:run-commands",
      "options": {
        "command": "next start --port 3401",
        "cwd": "{projectRoot}"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc --noEmit",
        "cwd": "{projectRoot}"
      },
      "dependsOn": ["codegen"]
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx oxlint@latest --jsx-a11y-plugin .",
        "cwd": "{projectRoot}"
      },
      "inputs": ["{projectRoot}/src/**/*", "{projectRoot}/oxlint.json", "{projectRoot}/tsconfig.json"]
    },
    "test:quick": {
      "executor": "nx:run-commands",
      "cache": true,
      "inputs": [
        "default",
        "{projectRoot}/src/generated-contracts/**/*",
        "{workspaceRoot}/specs/apps/a-demo/be/gherkin/**/*.feature",
        "{workspaceRoot}/specs/apps/a-demo/fe/gherkin/**/*.feature"
      ],
      "outputs": ["{projectRoot}/coverage"],
      "options": {
        "command": "npx vitest run --coverage && (test -f coverage/lcov.info && cd ../../apps/rhino-cli && CGO_ENABLED=0 go run main.go test-coverage validate apps/a-demo-fs-ts-nextjs/coverage/lcov.info 75 --exclude 'src/app/api/**' --exclude 'src/app/health/**' --exclude 'src/app/.well-known/**' --exclude 'src/repositories/**' --exclude 'src/db/**' --exclude 'src/lib/auth-middleware.ts' --exclude 'src/lib/api/**' --exclude 'src/lib/auth/**' --exclude 'src/lib/queries/**' --exclude 'src/app/layout.tsx' --exclude 'src/app/(dashboard)/layout.tsx' --exclude 'src/app/(dashboard)/expenses/new/**' --exclude 'src/components/**' --exclude 'src/app/page.tsx' || echo 'No coverage file yet — skipping validation')",
        "cwd": "{projectRoot}"
      }
    },
    "test:unit": {
      "executor": "nx:run-commands",
      "cache": true,
      "inputs": [
        "default",
        "{projectRoot}/src/generated-contracts/**/*",
        "{workspaceRoot}/specs/apps/a-demo/be/gherkin/**/*.feature",
        "{workspaceRoot}/specs/apps/a-demo/fe/gherkin/**/*.feature"
      ],
      "options": {
        "command": "npx vitest run",
        "cwd": "{projectRoot}"
      },
      "dependsOn": ["codegen"]
    },
    "test:integration": {
      "executor": "nx:run-commands",
      "options": {
        "command": "docker compose -f docker-compose.integration.yml down -v && docker compose -f docker-compose.integration.yml up --abort-on-container-exit --exit-code-from test-runner --build",
        "cwd": "apps/a-demo-fs-ts-nextjs"
      },
      "cache": false
    },
    "spec-coverage": {
      "command": "CGO_ENABLED=0 go run -C apps/rhino-cli main.go spec-coverage validate specs/apps/a-demo/fs/gherkin apps/a-demo-fs-ts-nextjs",
      "cache": true,
      "inputs": ["{workspaceRoot}/specs/apps/a-demo/fs/gherkin/**/*.feature", "{projectRoot}/**/*.{ts,tsx}"]
    }
  },
  "tags": ["type:app", "platform:nextjs", "lang:ts", "domain:a-demo-fs"],
  "implicitDependencies": ["a-demo-contracts", "rhino-cli"]
}
