{
  "name": "ayokoding-cli",
  "sourceRoot": "apps/ayokoding-cli",
  "projectType": "application",
  "tags": ["type:app", "platform:cli", "lang:golang", "domain:ayokoding"],
  "implicitDependencies": ["golang-commons", "hugo-commons"],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "go build -o dist/ayokoding-cli",
        "cwd": "apps/ayokoding-cli"
      },
      "outputs": ["{projectRoot}/dist"]
    },
    "test:quick": {
      "executor": "nx:run-commands",
      "options": {
        "command": "go test -coverprofile=cover.out ./... && (cd ../../apps/rhino-cli && CGO_ENABLED=0 go run main.go check-test-coverage apps/ayokoding-cli/cover.out 85)",
        "cwd": "apps/ayokoding-cli"
      }
    },
    "run": {
      "executor": "nx:run-commands",
      "options": {
        "command": "go run main.go",
        "cwd": "apps/ayokoding-cli"
      }
    },
    "install": {
      "executor": "nx:run-commands",
      "options": {
        "command": "go mod tidy",
        "cwd": "apps/ayokoding-cli"
      }
    },
    "test:integration": {
      "executor": "nx:run-commands",
      "options": {
        "command": "CGO_ENABLED=0 go test -v -tags=integration -run TestIntegration -coverprofile=cover_spec.out ./cmd/...",
        "cwd": "apps/ayokoding-cli"
      },
      "cache": true,
      "inputs": ["{projectRoot}/cmd/**/*.go", "{workspaceRoot}/specs/ayokoding-cli/**/*.feature"],
      "outputs": ["{projectRoot}/cover_spec.out"]
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "golangci-lint run --allow-parallel-runners ./...",
        "cwd": "apps/ayokoding-cli"
      }
    }
  }
}
