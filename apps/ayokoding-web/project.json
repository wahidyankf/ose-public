{
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "name": "ayokoding-web",
  "sourceRoot": "apps/ayokoding-web/src",
  "projectType": "application",
  "targets": {
    "codegen": {
      "executor": "nx:run-commands",
      "options": {
        "command": "echo 'No codegen needed — ayokoding-web has no OpenAPI contract'",
        "cwd": "{projectRoot}"
      }
    },
    "generate-indexes": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx tsx src/scripts/generate-indexes.ts",
        "cwd": "{projectRoot}"
      }
    },
    "validate-indexes": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx tsx src/scripts/generate-indexes.ts --validate",
        "cwd": "{projectRoot}"
      }
    },
    "generate-search-data": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx tsx src/scripts/generate-search-data.ts",
        "cwd": "{projectRoot}"
      }
    },
    "dev": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx tsx src/scripts/generate-indexes.ts && next dev --port 3101",
        "cwd": "{projectRoot}"
      }
    },
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "next build",
        "cwd": "{projectRoot}"
      },
      "outputs": ["{projectRoot}/.next"],
      "dependsOn": ["generate-indexes", "generate-search-data"]
    },
    "start": {
      "executor": "nx:run-commands",
      "options": {
        "command": "next start --port 3101",
        "cwd": "{projectRoot}"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc --noEmit",
        "cwd": "{projectRoot}"
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx oxlint@latest --jsx-a11y-plugin .",
        "cwd": "{projectRoot}"
      }
    },
    "test:unit": {
      "executor": "nx:run-commands",
      "cache": true,
      "inputs": ["default", "{workspaceRoot}/specs/apps/ayokoding/**/*.feature"],
      "options": {
        "command": "npx vitest run --project unit --project unit-fe",
        "cwd": "{projectRoot}"
      }
    },
    "test:quick": {
      "executor": "nx:run-commands",
      "dependsOn": ["ayokoding-cli:build"],
      "inputs": ["default", "{workspaceRoot}/specs/apps/ayokoding/**/*.feature"],
      "options": {
        "commands": [
          "npx vitest run --project unit --project unit-fe --coverage && (cd ../../apps/rhino-cli && CGO_ENABLED=0 go run main.go test-coverage validate apps/ayokoding-web/coverage/lcov.info 80)",
          "../../apps/ayokoding-cli/dist/ayokoding-cli links check --content content",
          "npx tsx src/scripts/generate-indexes.ts --validate"
        ],
        "parallel": true,
        "cwd": "{projectRoot}"
      }
    },
    "test:integration": {
      "executor": "nx:run-commands",
      "inputs": ["default", "{workspaceRoot}/specs/apps/ayokoding/**/*.feature"],
      "options": {
        "command": "npx vitest run --project integration",
        "cwd": "{projectRoot}"
      },
      "cache": false
    },
    "spec-coverage": {
      "command": "CGO_ENABLED=0 go run -C apps/rhino-cli main.go spec-coverage validate specs/apps/ayokoding/be/gherkin apps/ayokoding-web",
      "cache": true,
      "inputs": [
        "{workspaceRoot}/specs/apps/ayokoding/be/gherkin/**/*.feature",
        "{workspaceRoot}/specs/apps/ayokoding/fe/gherkin/**/*.feature",
        "{projectRoot}/**/*.{ts,tsx}"
      ]
    }
  },
  "tags": ["type:app", "platform:nextjs", "lang:ts", "domain:ayokoding"],
  "implicitDependencies": ["rhino-cli", "ayokoding-cli"]
}
