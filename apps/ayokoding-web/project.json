{
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "name": "ayokoding-web",
  "sourceRoot": "apps/ayokoding-web/src",
  "projectType": "application",
  "targets": {
    "codegen": {
      "executor": "nx:run-commands",
      "options": {
        "command": "echo 'No codegen needed — ayokoding-web has no OpenAPI contract'",
        "cwd": "{projectRoot}"
      }
    },
    "dev": {
      "executor": "nx:run-commands",
      "options": {
        "command": "next dev --port 3101",
        "cwd": "{projectRoot}"
      }
    },
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "next build",
        "cwd": "{projectRoot}"
      },
      "outputs": ["{projectRoot}/.next"],
      "dependsOn": []
    },
    "start": {
      "executor": "nx:run-commands",
      "options": {
        "command": "next start --port 3101",
        "cwd": "{projectRoot}"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc --noEmit",
        "cwd": "{projectRoot}"
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx oxlint@latest .",
        "cwd": "{projectRoot}"
      }
    },
    "test:unit": {
      "executor": "nx:run-commands",
      "cache": true,
      "inputs": ["default", "{workspaceRoot}/specs/apps/ayokoding-web/**/*.feature"],
      "options": {
        "command": "npx vitest run --project unit --project unit-fe",
        "cwd": "{projectRoot}"
      }
    },
    "test:quick": {
      "executor": "nx:run-commands",
      "dependsOn": ["ayokoding-cli:build"],
      "inputs": ["default", "{workspaceRoot}/specs/apps/ayokoding-web/**/*.feature"],
      "options": {
        "commands": [
          "npx vitest run --project unit --project unit-fe --coverage && (cd ../../apps/rhino-cli && CGO_ENABLED=0 go run main.go test-coverage validate apps/ayokoding-web/coverage/lcov.info 80)",
          "../../apps/ayokoding-cli/dist/ayokoding-cli links check --content content"
        ],
        "parallel": true,
        "cwd": "{projectRoot}"
      }
    },
    "test:integration": {
      "executor": "nx:run-commands",
      "inputs": ["default", "{workspaceRoot}/specs/apps/ayokoding-web/**/*.feature"],
      "options": {
        "command": "npx vitest run --project integration",
        "cwd": "{projectRoot}"
      },
      "cache": false
    }
  },
  "tags": ["type:app", "platform:nextjs", "lang:ts", "domain:ayokoding"],
  "implicitDependencies": ["rhino-cli", "ayokoding-cli"]
}
