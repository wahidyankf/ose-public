{
  "name": "demo-be-clojure-pedestal",
  "sourceRoot": "apps/demo-be-clojure-pedestal",
  "projectType": "application",
  "tags": ["type:app", "platform:pedestal", "lang:clojure", "domain:demo-be"],
  "targets": {
    "codegen": {
      "executor": "nx:run-commands",
      "options": {
        "command": "JAVA_HOME=${JAVA_HOME_21_X64:-$JAVA_HOME} cd libs/clojure-openapi-codegen && clojure -M -e '(require (quote openapi-codegen.core)) (openapi-codegen.core/generate \"../../specs/apps/demo/contracts/generated/openapi-bundled.yaml\" \"../../apps/demo-be-clojure-pedestal/generated_contracts\")'"
      },
      "dependsOn": ["demo-contracts:bundle", "clojure-openapi-codegen:build"],
      "cache": true,
      "inputs": ["{workspaceRoot}/specs/apps/demo/contracts/generated/openapi-bundled.yaml"],
      "outputs": ["{projectRoot}/generated_contracts"]
    },
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "JAVA_HOME=${JAVA_HOME_21_X64:-$JAVA_HOME} clojure -T:build uber",
        "cwd": "apps/demo-be-clojure-pedestal"
      },
      "dependsOn": ["codegen"],
      "outputs": ["{projectRoot}/target"]
    },
    "dev": {
      "executor": "nx:run-commands",
      "options": {
        "command": "JAVA_HOME=${JAVA_HOME_21_X64:-$JAVA_HOME} clojure -M -m demo-be-cjpd.main",
        "cwd": "apps/demo-be-clojure-pedestal"
      }
    },
    "start": {
      "executor": "nx:run-commands",
      "options": {
        "command": "java -jar target/demo-be-clojure-pedestal-standalone.jar",
        "cwd": "apps/demo-be-clojure-pedestal"
      }
    },
    "test:quick": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          "JAVA_HOME=${JAVA_HOME_21_X64:-$JAVA_HOME} clojure -M:coverage -m kaocha.runner unit bdd --plugin cloverage --lcov --cov-output coverage --cov-ns-exclude-regex 'demo-be-cjpd\\.(main|routes|server|interceptors\\..*)'",
          "(cd ../../ && CGO_ENABLED=0 go run apps/rhino-cli/main.go test-coverage validate apps/demo-be-clojure-pedestal/coverage/lcov.info 90)"
        ],
        "parallel": false,
        "cwd": "apps/demo-be-clojure-pedestal"
      },
      "cache": true,
      "inputs": [
        "{projectRoot}/src/**/*",
        "{projectRoot}/test/**/*",
        "{projectRoot}/tests.edn",
        "{projectRoot}/generated_contracts/**/*",
        "{workspaceRoot}/specs/apps/demo/be/gherkin/**/*.feature"
      ],
      "outputs": ["{projectRoot}/coverage"]
    },
    "test:unit": {
      "executor": "nx:run-commands",
      "options": {
        "command": "JAVA_HOME=${JAVA_HOME_21_X64:-$JAVA_HOME} clojure -M:test -m kaocha.runner unit bdd",
        "cwd": "apps/demo-be-clojure-pedestal"
      },
      "cache": true,
      "inputs": [
        "{projectRoot}/src/**/*",
        "{projectRoot}/test/**/*",
        "{projectRoot}/tests.edn",
        "{projectRoot}/generated_contracts/**/*",
        "{workspaceRoot}/specs/apps/demo/be/gherkin/**/*.feature"
      ]
    },
    "test:integration": {
      "executor": "nx:run-commands",
      "options": {
        "command": "docker compose -f docker-compose.integration.yml down -v && docker compose -f docker-compose.integration.yml up --abort-on-container-exit --build",
        "cwd": "apps/demo-be-clojure-pedestal"
      },
      "cache": false
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "clj-kondo --lint src test",
        "cwd": "apps/demo-be-clojure-pedestal"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "clj-kondo --lint src",
        "cwd": "apps/demo-be-clojure-pedestal"
      },
      "dependsOn": ["codegen"],
      "cache": true
    }
  },
  "implicitDependencies": ["demo-contracts", "rhino-cli"]
}
