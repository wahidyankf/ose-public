#kaocha/v1
{:tests
 [{:id          :unit
   :type        :kaocha.type/clojure.test
   :source-paths ["src"]
   :test-paths  ["test"]
   :ns-patterns ["demo-be-cjpd\\..*-test"]}

  ;; BDD-level tests: kaocha-cucumber with in-memory SQLite — no external services required.
  ;; These run at the "unit" level (fast, deterministic, no Docker).
  {:id          :bdd
   :type        :kaocha.type/cucumber
   :source-paths ["src"]
   :test-paths  ["test/features"]
   :cucumber/glue-paths  ["test/step_definitions"]}]}
