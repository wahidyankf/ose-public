{
  "name": "demo-be-e2e",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "apps/demo-be-e2e/tests",
  "targets": {
    "install": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npm install",
        "cwd": "apps/demo-be-e2e"
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx oxlint@latest .",
        "cwd": "apps/demo-be-e2e"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx bddgen && npx tsc --noEmit",
        "cwd": "apps/demo-be-e2e"
      },
      "inputs": [
        "default",
        "{workspaceRoot}/specs/apps/demo/be/gherkin/**/*.feature"
      ]
    },
    "test:quick": {
      "executor": "nx:run-commands",
      "options": {
        "commands": ["npx oxlint@latest .", "npx bddgen && npx tsc --noEmit"],
        "parallel": true,
        "cwd": "apps/demo-be-e2e"
      },
      "inputs": [
        "default",
        "{workspaceRoot}/specs/apps/demo/be/gherkin/**/*.feature"
      ]
    },
    "test:e2e": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx bddgen && npx playwright test",
        "cwd": "apps/demo-be-e2e"
      }
    },
    "test:e2e:no-test-api": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx bddgen && npx playwright test --grep-invert 'Test Support API'",
        "cwd": "apps/demo-be-e2e"
      }
    },
    "test:e2e:shard": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx bddgen && npx playwright test --shard=${SHARD}",
        "cwd": "apps/demo-be-e2e"
      }
    },
    "test:e2e:ui": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx bddgen && npx playwright test --ui",
        "cwd": "apps/demo-be-e2e"
      }
    },
    "test:e2e:report": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx playwright show-report",
        "cwd": "apps/demo-be-e2e"
      }
    }
  },
  "tags": ["type:e2e", "platform:playwright", "lang:ts", "domain:demo-be"],
  "implicitDependencies": [
    "demo-be-java-springboot",
    "demo-be-elixir-phoenix",
    "demo-be-fsharp-giraffe",
    "demo-be-golang-gin",
    "demo-be-python-fastapi",
    "demo-be-rust-axum",
    "demo-be-kotlin-ktor",
    "demo-be-java-vertx",
    "demo-be-ts-effect",
    "demo-be-csharp-aspnetcore",
    "demo-be-clojure-pedestal"
  ]
}
