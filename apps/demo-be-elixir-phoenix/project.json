{
  "name": "demo-be-elixir-phoenix",
  "sourceRoot": "apps/demo-be-elixir-phoenix/lib",
  "projectType": "application",
  "implicitDependencies": ["demo-contracts", "elixir-gherkin", "elixir-cabbage", "elixir-openapi-codegen", "rhino-cli"],
  "targets": {
    "codegen": {
      "executor": "nx:run-commands",
      "options": {
        "command": "cd libs/elixir-openapi-codegen && mix run -e 'OpenApiCodegen.generate(\"../../specs/apps/demo/contracts/generated/openapi-bundled.yaml\", \"../../apps/demo-be-elixir-phoenix/generated-contracts\")'"
      },
      "dependsOn": ["demo-contracts:bundle", "elixir-openapi-codegen:build"],
      "cache": true,
      "inputs": ["{workspaceRoot}/specs/apps/demo/contracts/generated/openapi-bundled.yaml"],
      "outputs": ["{projectRoot}/generated-contracts"]
    },
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "MIX_ENV=prod mix do deps.get --only prod, compile --warnings-as-errors",
        "cwd": "apps/demo-be-elixir-phoenix"
      },
      "dependsOn": ["codegen"]
    },
    "dev": {
      "executor": "nx:run-commands",
      "options": {
        "command": "mix phx.server",
        "cwd": "apps/demo-be-elixir-phoenix"
      }
    },
    "start": {
      "executor": "nx:run-commands",
      "options": {
        "command": "mix phx.server",
        "cwd": "apps/demo-be-elixir-phoenix"
      }
    },
    "test:quick": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          "MIX_ENV=test mix coveralls.lcov --only unit",
          "(cd ../../apps/rhino-cli && CGO_ENABLED=0 go run main.go test-coverage validate apps/demo-be-elixir-phoenix/cover/lcov.info 90)"
        ],
        "parallel": false,
        "cwd": "apps/demo-be-elixir-phoenix"
      },
      "cache": true,
      "inputs": [
        "{projectRoot}/lib/**/*.ex",
        "{projectRoot}/test/**/*.exs",
        "{projectRoot}/generated-contracts/**/*",
        "{workspaceRoot}/specs/apps/demo/be/gherkin/**/*.feature"
      ],
      "outputs": ["{projectRoot}/cover/lcov.info"]
    },
    "test:unit": {
      "executor": "nx:run-commands",
      "options": {
        "command": "MIX_ENV=test mix test --only unit",
        "cwd": "apps/demo-be-elixir-phoenix"
      },
      "cache": true,
      "inputs": [
        "{projectRoot}/lib/**/*.ex",
        "{projectRoot}/test/**/*.exs",
        "{projectRoot}/generated-contracts/**/*",
        "{workspaceRoot}/specs/apps/demo/be/gherkin/**/*.feature"
      ]
    },
    "test:integration": {
      "executor": "nx:run-commands",
      "options": {
        "command": "docker compose -f docker-compose.integration.yml down -v && docker compose -f docker-compose.integration.yml up --abort-on-container-exit --build",
        "cwd": "apps/demo-be-elixir-phoenix"
      },
      "cache": false
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "mix credo --strict",
        "cwd": "apps/demo-be-elixir-phoenix"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "mix compile --warnings-as-errors",
        "cwd": "apps/demo-be-elixir-phoenix"
      },
      "dependsOn": ["codegen"],
      "cache": true
    },
    "install": {
      "executor": "nx:run-commands",
      "options": {
        "command": "mix deps.get",
        "cwd": "apps/demo-be-elixir-phoenix"
      }
    }
  },
  "tags": ["type:app", "platform:phoenix", "lang:elixir", "domain:demo-be"]
}
