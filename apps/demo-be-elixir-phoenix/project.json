{
  "name": "demo-be-elixir-phoenix",
  "sourceRoot": "apps/demo-be-elixir-phoenix/lib",
  "projectType": "application",
  "implicitDependencies": ["elixir-gherkin", "elixir-cabbage"],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "MIX_ENV=prod mix do deps.get --only prod, compile --warnings-as-errors",
        "cwd": "apps/demo-be-elixir-phoenix"
      }
    },
    "dev": {
      "executor": "nx:run-commands",
      "options": {
        "command": "mix phx.server",
        "cwd": "apps/demo-be-elixir-phoenix"
      }
    },
    "start": {
      "executor": "nx:run-commands",
      "options": {
        "command": "mix phx.server",
        "cwd": "apps/demo-be-elixir-phoenix"
      }
    },
    "test:quick": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          "MIX_ENV=test mix coveralls.lcov --only unit",
          "(cd ../../apps/rhino-cli && CGO_ENABLED=0 go run main.go test-coverage validate apps/demo-be-elixir-phoenix/cover/lcov.info 90)"
        ],
        "parallel": false,
        "cwd": "apps/demo-be-elixir-phoenix"
      },
      "inputs": [
        "{projectRoot}/lib/**/*.ex",
        "{projectRoot}/test/**/*.exs",
        "{workspaceRoot}/specs/apps/demo-be/gherkin/**/*.feature"
      ]
    },
    "test:unit": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          "MIX_ENV=test mix coveralls.lcov --only unit",
          "(cd ../../apps/rhino-cli && CGO_ENABLED=0 go run main.go test-coverage validate apps/demo-be-elixir-phoenix/cover/lcov.info 90)"
        ],
        "parallel": false,
        "cwd": "apps/demo-be-elixir-phoenix"
      },
      "inputs": [
        "{projectRoot}/lib/**/*.ex",
        "{projectRoot}/test/**/*.exs",
        "{workspaceRoot}/specs/apps/demo-be/gherkin/**/*.feature"
      ]
    },
    "test:integration": {
      "executor": "nx:run-commands",
      "options": {
        "command": "docker compose -f docker-compose.integration.yml down -v && docker compose -f docker-compose.integration.yml up --abort-on-container-exit --build",
        "cwd": "apps/demo-be-elixir-phoenix"
      },
      "cache": false
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "mix credo --strict",
        "cwd": "apps/demo-be-elixir-phoenix"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "mix compile --warnings-as-errors",
        "cwd": "apps/demo-be-elixir-phoenix"
      }
    },
    "install": {
      "executor": "nx:run-commands",
      "options": {
        "command": "mix deps.get",
        "cwd": "apps/demo-be-elixir-phoenix"
      }
    }
  },
  "tags": ["type:app", "platform:phoenix", "lang:elixir", "domain:demo-be"]
}
