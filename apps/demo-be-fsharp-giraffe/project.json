{
  "name": "demo-be-fsharp-giraffe",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/demo-be-fsharp-giraffe/src",
  "projectType": "application",
  "targets": {
    "codegen": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx openapi-generator-cli generate -i $(pwd)/specs/apps/demo/contracts/generated/openapi-bundled.yaml -g fsharp-giraffe-server -o $(pwd)/apps/demo-be-fsharp-giraffe/generated-contracts --model-package DemoBeFsgi.Contracts --global-property=models,modelDocs=false,apiDocs=false"
      },
      "dependsOn": ["demo-contracts:bundle"],
      "cache": true,
      "inputs": ["{workspaceRoot}/specs/apps/demo/contracts/generated/openapi-bundled.yaml"],
      "outputs": ["{projectRoot}/generated-contracts"]
    },
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "dotnet publish src/DemoBeFsgi/DemoBeFsgi.fsproj -c Release -o dist",
        "cwd": "apps/demo-be-fsharp-giraffe"
      },
      "outputs": ["{projectRoot}/dist"],
      "dependsOn": ["codegen"]
    },
    "dev": {
      "executor": "nx:run-commands",
      "options": {
        "command": "dotnet watch run --project src/DemoBeFsgi/DemoBeFsgi.fsproj",
        "cwd": "apps/demo-be-fsharp-giraffe"
      }
    },
    "start": {
      "executor": "nx:run-commands",
      "options": {
        "command": "dotnet run --project src/DemoBeFsgi/DemoBeFsgi.fsproj",
        "cwd": "apps/demo-be-fsharp-giraffe"
      }
    },
    "test:quick": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          "dotnet tool restore",
          "dotnet build tests/DemoBeFsgi.Tests/DemoBeFsgi.Tests.fsproj",
          "dotnet altcover --inputDirectory tests/DemoBeFsgi.Tests/bin/Debug/net10.0 --outputDirectory tests/DemoBeFsgi.Tests/bin/Debug/net10.0/__Instrumented --assemblyExcludeFilter=DemoBeFsgi.Tests '--assemblyFilter=xunit|TickSpec|Microsoft|FSharp|testhost|AltCover|coverlet' --fileFilter=TestHandler --linecover --reportFormat=lcov --report=coverage/altcov.info --save",
          "dotnet altcover Runner --recorderDirectory tests/DemoBeFsgi.Tests/bin/Debug/net10.0/__Instrumented --lcovReport coverage/altcov.info --executable dotnet -- test tests/DemoBeFsgi.Tests/bin/Debug/net10.0/__Instrumented/DemoBeFsgi.Tests.dll",
          "(cd ../../apps/rhino-cli && CGO_ENABLED=0 go run main.go test-coverage validate apps/demo-be-fsharp-giraffe/coverage/altcov.info 90)"
        ],
        "parallel": false,
        "cwd": "apps/demo-be-fsharp-giraffe"
      },
      "cache": true,
      "inputs": [
        "{projectRoot}/src/**/*.fs",
        "{projectRoot}/tests/**/*.fs",
        "{projectRoot}/generated-contracts/**/*",
        "{workspaceRoot}/specs/apps/demo/be/gherkin/**/*.feature"
      ],
      "outputs": ["{projectRoot}/coverage/altcov.info"]
    },
    "test:unit": {
      "executor": "nx:run-commands",
      "options": {
        "command": "dotnet test tests/DemoBeFsgi.Tests/DemoBeFsgi.Tests.fsproj --filter Category=Unit",
        "cwd": "apps/demo-be-fsharp-giraffe"
      },
      "cache": true,
      "inputs": [
        "{projectRoot}/src/**/*.fs",
        "{projectRoot}/tests/**/*.fs",
        "{projectRoot}/generated-contracts/**/*",
        "{workspaceRoot}/specs/apps/demo/be/gherkin/**/*.feature"
      ]
    },
    "test:integration": {
      "executor": "nx:run-commands",
      "options": {
        "command": "docker compose -f docker-compose.integration.yml down -v && docker compose -f docker-compose.integration.yml up --abort-on-container-exit --build",
        "cwd": "apps/demo-be-fsharp-giraffe"
      },
      "cache": false
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          "DOTNET_ROOT=$(dirname $(readlink -f $(which dotnet))) DOTNET_ROLL_FORWARD=LatestMajor fantomas --check src/ tests/",
          "DOTNET_ROOT=$(dirname $(readlink -f $(which dotnet))) DOTNET_ROLL_FORWARD=LatestMajor dotnet fsharplint lint --lint-config fsharplint.json src/DemoBeFsgi/DemoBeFsgi.fsproj"
        ],
        "parallel": false,
        "cwd": "apps/demo-be-fsharp-giraffe"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "dotnet build src/DemoBeFsgi/DemoBeFsgi.fsproj --no-restore /p:TreatWarningsAsErrors=true",
        "cwd": "apps/demo-be-fsharp-giraffe"
      },
      "dependsOn": ["codegen"],
      "cache": true
    }
  },
  "tags": ["type:app", "platform:giraffe", "lang:fsharp", "domain:demo-be"],
  "implicitDependencies": ["rhino-cli"]
}
