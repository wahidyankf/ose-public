{
  "name": "demo-be-java-springboot",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/demo-be-java-springboot/src",
  "projectType": "application",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "mvn clean package -DskipTests",
        "cwd": "apps/demo-be-java-springboot"
      },
      "outputs": ["{projectRoot}/target"],
      "dependsOn": []
    },
    "dev": {
      "executor": "nx:run-commands",
      "options": {
        "command": "mvn spring-boot:run -Dspring-boot.run.profiles=dev",
        "cwd": "apps/demo-be-java-springboot"
      }
    },
    "start": {
      "executor": "nx:run-commands",
      "options": {
        "command": "sh -c 'java -jar target/demo-be-java-springboot-*.jar'",
        "cwd": "apps/demo-be-java-springboot"
      }
    },
    "test:quick": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          "mvn test",
          "(cd ../../apps/rhino-cli && CGO_ENABLED=0 go run main.go test-coverage validate apps/demo-be-java-springboot/target/site/jacoco/jacoco.xml 90)"
        ],
        "parallel": false,
        "cwd": "apps/demo-be-java-springboot"
      },
      "inputs": [
        "{projectRoot}/src/**",
        "{projectRoot}/pom.xml",
        "{workspaceRoot}/specs/apps/demo-be/gherkin/**/*.feature"
      ]
    },
    "test:unit": {
      "executor": "nx:run-commands",
      "options": {
        "command": "mvn test",
        "cwd": "apps/demo-be-java-springboot"
      },
      "inputs": [
        "{projectRoot}/src/**",
        "{projectRoot}/pom.xml",
        "{workspaceRoot}/specs/apps/demo-be/gherkin/**/*.feature"
      ]
    },
    "test:integration": {
      "executor": "nx:run-commands",
      "options": {
        "command": "mvn test -Pintegration",
        "cwd": "apps/demo-be-java-springboot"
      },
      "cache": false
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "mvn checkstyle:check",
        "cwd": "apps/demo-be-java-springboot"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          "nx run rhino-cli:build --skip-nx-cache && ./apps/rhino-cli/dist/rhino-cli java validate-annotations apps/demo-be-java-springboot/src/main/java",
          "cd apps/demo-be-java-springboot && mvn compile -Pnullcheck"
        ],
        "parallel": false
      }
    }
  },
  "tags": ["type:app", "platform:spring-boot", "lang:java", "domain:demo-be"],
  "implicitDependencies": ["rhino-cli"]
}
