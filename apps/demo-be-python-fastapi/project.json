{
  "name": "demo-be-python-fastapi",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/demo-be-python-fastapi/src",
  "projectType": "application",
  "targets": {
    "codegen": {
      "executor": "nx:run-commands",
      "options": {
        "command": "mkdir -p apps/demo-be-python-fastapi/generated_contracts && datamodel-codegen --input $(pwd)/specs/apps/demo/contracts/generated/openapi-bundled.yaml --input-file-type openapi --output $(pwd)/apps/demo-be-python-fastapi/generated_contracts/__init__.py --output-model-type pydantic_v2.BaseModel --target-python-version 3.12"
      },
      "dependsOn": ["demo-contracts:bundle"],
      "cache": true,
      "inputs": ["{workspaceRoot}/specs/apps/demo/contracts/generated/openapi-bundled.yaml"],
      "outputs": ["{projectRoot}/generated_contracts"]
    },
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "uv build",
        "cwd": "apps/demo-be-python-fastapi"
      },
      "outputs": ["{projectRoot}/dist"]
    },
    "dev": {
      "executor": "nx:run-commands",
      "options": {
        "command": "uv run uvicorn demo_be_python_fastapi.main:app --reload --port 8201",
        "cwd": "apps/demo-be-python-fastapi"
      }
    },
    "start": {
      "executor": "nx:run-commands",
      "options": {
        "command": "uv run uvicorn demo_be_python_fastapi.main:app --port 8201",
        "cwd": "apps/demo-be-python-fastapi"
      }
    },
    "test:quick": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          "uv run coverage run -m pytest -m unit",
          "uv run coverage lcov -o coverage/lcov.info",
          "(cd ../../apps/rhino-cli && CGO_ENABLED=0 go run main.go test-coverage validate apps/demo-be-python-fastapi/coverage/lcov.info 90)"
        ],
        "parallel": false,
        "cwd": "apps/demo-be-python-fastapi"
      },
      "inputs": [
        "{projectRoot}/src/**/*.py",
        "{projectRoot}/tests/**/*.py",
        "{workspaceRoot}/specs/apps/demo/be/gherkin/**/*.feature"
      ]
    },
    "test:unit": {
      "executor": "nx:run-commands",
      "options": {
        "command": "uv run pytest -m unit",
        "cwd": "apps/demo-be-python-fastapi"
      },
      "inputs": [
        "{projectRoot}/src/**/*.py",
        "{projectRoot}/tests/**/*.py",
        "{workspaceRoot}/specs/apps/demo/be/gherkin/**/*.feature"
      ]
    },
    "test:integration": {
      "executor": "nx:run-commands",
      "options": {
        "command": "docker compose -f docker-compose.integration.yml down -v && docker compose -f docker-compose.integration.yml up --abort-on-container-exit --build",
        "cwd": "apps/demo-be-python-fastapi"
      },
      "cache": false
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "uv run ruff check .",
        "cwd": "apps/demo-be-python-fastapi"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "uv run pyright",
        "cwd": "apps/demo-be-python-fastapi"
      }
    }
  },
  "tags": ["type:app", "platform:fastapi", "lang:python", "domain:demo-be"],
  "implicitDependencies": ["rhino-cli"]
}
