{
  "name": "demo-be-rust-axum",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/demo-be-rust-axum/src",
  "projectType": "application",
  "targets": {
    "codegen": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx openapi-generator-cli generate -i $(pwd)/specs/apps/demo/contracts/generated/openapi-bundled.yaml -g rust -o $(pwd)/apps/demo-be-rust-axum/generated-contracts --additional-properties=library=reqwest,packageName=demo-contracts --global-property=models,modelDocs=false,apiDocs=false"
      },
      "dependsOn": ["demo-contracts:bundle"],
      "cache": true,
      "inputs": ["{workspaceRoot}/specs/apps/demo/contracts/generated/openapi-bundled.yaml"],
      "outputs": ["{projectRoot}/generated-contracts"]
    },
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "cargo build --release",
        "cwd": "apps/demo-be-rust-axum"
      },
      "outputs": ["{projectRoot}/target/release/demo-be-rust-axum"],
      "dependsOn": []
    },
    "dev": {
      "executor": "nx:run-commands",
      "options": {
        "command": "APP_JWT_SECRET=dev-jwt-secret-that-is-32-chars-long! cargo run",
        "cwd": "apps/demo-be-rust-axum"
      }
    },
    "start": {
      "executor": "nx:run-commands",
      "options": {
        "command": "APP_JWT_SECRET=dev-jwt-secret-that-is-32-chars-long! ./target/release/demo-be-rust-axum",
        "cwd": "apps/demo-be-rust-axum"
      }
    },
    "test:quick": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          "cargo test --lib --test unit",
          "mkdir -p coverage && cargo llvm-cov --lcov --output-path coverage/lcov.info --lib --test unit --ignore-filename-regex 'test_api'",
          "(cd ../../apps/rhino-cli && CGO_ENABLED=0 go run main.go test-coverage validate apps/demo-be-rust-axum/coverage/lcov.info 90)"
        ],
        "parallel": false,
        "cwd": "apps/demo-be-rust-axum"
      },
      "cache": true,
      "inputs": [
        "{projectRoot}/src/**/*.rs",
        "{projectRoot}/tests/unit/**/*.rs",
        "{projectRoot}/Cargo.toml",
        "{projectRoot}/Cargo.lock",
        "{workspaceRoot}/specs/apps/demo/be/gherkin/**/*.feature"
      ],
      "outputs": ["{projectRoot}/coverage/lcov.info"]
    },
    "test:unit": {
      "executor": "nx:run-commands",
      "options": {
        "command": "cargo test --lib --test unit",
        "cwd": "apps/demo-be-rust-axum"
      },
      "cache": true,
      "inputs": [
        "{projectRoot}/src/**/*.rs",
        "{projectRoot}/tests/unit/**/*.rs",
        "{projectRoot}/Cargo.toml",
        "{projectRoot}/Cargo.lock",
        "{workspaceRoot}/specs/apps/demo/be/gherkin/**/*.feature"
      ]
    },
    "test:integration": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          "docker compose -f docker-compose.integration.yml down -v",
          "docker compose -f docker-compose.integration.yml up --abort-on-container-exit --build"
        ],
        "parallel": false,
        "cwd": "apps/demo-be-rust-axum"
      },
      "cache": false
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "commands": ["cargo fmt --check", "cargo clippy -- -D warnings"],
        "parallel": false,
        "cwd": "apps/demo-be-rust-axum"
      }
    }
  },
  "tags": ["type:app", "platform:axum", "lang:rust", "domain:demo-be"],
  "implicitDependencies": ["rhino-cli"]
}
