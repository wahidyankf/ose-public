{
  "name": "demo-be-ts-effect",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/demo-be-ts-effect/src",
  "projectType": "application",
  "targets": {
    "codegen": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx @hey-api/openapi-ts -i specs/apps/demo/contracts/generated/openapi-bundled.yaml -o apps/demo-be-ts-effect/generated-contracts -s"
      },
      "dependsOn": ["demo-contracts:bundle"],
      "cache": true,
      "inputs": ["{workspaceRoot}/specs/apps/demo/contracts/generated/openapi-bundled.yaml"],
      "outputs": ["{projectRoot}/generated-contracts"]
    },
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx vite build",
        "cwd": "apps/demo-be-ts-effect"
      },
      "dependsOn": ["codegen"],
      "outputs": ["{projectRoot}/dist"]
    },
    "dev": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx tsx watch src/main.ts",
        "cwd": "apps/demo-be-ts-effect"
      }
    },
    "start": {
      "executor": "nx:run-commands",
      "options": {
        "command": "node dist/main.js",
        "cwd": "apps/demo-be-ts-effect"
      }
    },
    "test:quick": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          "npx vitest run --coverage",
          "(cd ../../apps/rhino-cli && CGO_ENABLED=0 go run main.go test-coverage validate apps/demo-be-ts-effect/coverage/lcov.info 90)",
          "npx cucumber-js '../../specs/apps/demo/be/gherkin/**/*.feature' --require-module tsx/cjs --require 'tests/unit/bdd/hooks.ts' --require 'tests/unit/bdd/world.ts' --require 'tests/unit/bdd/steps/**/*.ts' --format progress --format 'json:coverage/cucumber-unit-report.json'"
        ],
        "parallel": false,
        "cwd": "apps/demo-be-ts-effect"
      },
      "cache": true,
      "inputs": [
        "{projectRoot}/src/**/*.ts",
        "{projectRoot}/tests/unit/**/*.ts",
        "{projectRoot}/vitest.config.ts",
        "{projectRoot}/generated-contracts/**/*",
        "{workspaceRoot}/specs/apps/demo/be/gherkin/**/*.feature"
      ],
      "outputs": ["{projectRoot}/coverage"]
    },
    "test:unit": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          "npx vitest run tests/unit",
          "npx cucumber-js '../../specs/apps/demo/be/gherkin/**/*.feature' --require-module tsx/cjs --require 'tests/unit/bdd/hooks.ts' --require 'tests/unit/bdd/world.ts' --require 'tests/unit/bdd/steps/**/*.ts' --format progress --format 'json:coverage/cucumber-unit-report.json'"
        ],
        "parallel": false,
        "cwd": "apps/demo-be-ts-effect"
      },
      "cache": true,
      "inputs": [
        "{projectRoot}/src/**/*.ts",
        "{projectRoot}/tests/unit/**/*.ts",
        "{projectRoot}/generated-contracts/**/*",
        "{workspaceRoot}/specs/apps/demo/be/gherkin/**/*.feature"
      ]
    },
    "test:integration": {
      "executor": "nx:run-commands",
      "options": {
        "command": "docker compose -f docker-compose.integration.yml down -v && docker compose -f docker-compose.integration.yml up --abort-on-container-exit --exit-code-from test-runner --build",
        "cwd": "apps/demo-be-ts-effect"
      },
      "cache": false
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx oxlint .",
        "cwd": "apps/demo-be-ts-effect"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx tsc --noEmit",
        "cwd": "apps/demo-be-ts-effect"
      },
      "dependsOn": ["codegen"],
      "cache": true
    }
  },
  "tags": ["type:app", "platform:effect", "lang:typescript", "domain:demo-be"],
  "implicitDependencies": ["demo-contracts", "rhino-cli"]
}
