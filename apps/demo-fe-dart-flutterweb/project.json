{
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "name": "demo-fe-dart-flutterweb",
  "sourceRoot": "apps/demo-fe-dart-flutterweb/lib",
  "projectType": "application",
  "targets": {
    "codegen": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx openapi-generator-cli generate -i $(pwd)/specs/apps/demo/contracts/generated/openapi-bundled.yaml -g dart -o $(pwd)/apps/demo-fe-dart-flutterweb/generated-contracts --additional-properties=pubName=demo_contracts --global-property=models,modelDocs=false,apiDocs=false"
      },
      "dependsOn": ["demo-contracts:bundle"],
      "cache": true,
      "inputs": ["{workspaceRoot}/specs/apps/demo/contracts/generated/openapi-bundled.yaml"],
      "outputs": ["{projectRoot}/generated-contracts"]
    },
    "dev": {
      "executor": "nx:run-commands",
      "options": {
        "command": "flutter run -d chrome --web-port 3301",
        "cwd": "{projectRoot}"
      }
    },
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "flutter build web --release",
        "cwd": "{projectRoot}"
      },
      "outputs": ["{projectRoot}/build/web"],
      "dependsOn": []
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "dart analyze --fatal-infos",
        "cwd": "{projectRoot}"
      }
    },
    "test:quick": {
      "executor": "nx:run-commands",
      "options": {
        "command": "dart analyze --fatal-infos && flutter test test/unit",
        "cwd": "{projectRoot}"
      }
    },
    "test:unit": {
      "executor": "nx:run-commands",
      "options": {
        "command": "flutter test test/unit",
        "cwd": "{projectRoot}"
      }
    }
  },
  "tags": ["type:app", "platform:flutter", "lang:dart", "domain:demo-fe"],
  "implicitDependencies": []
}
