{
  "rules": {
    "naming": {
      "enabled": true,
      "config": {
        "interfaceNames": { "enabled": true, "naming": "PascalCase", "prefix": "I", "suffix": null },
        "exceptionNames": { "enabled": true, "naming": "PascalCase", "prefix": null, "suffix": "Exception" },
        "typeNames": { "enabled": true, "naming": "PascalCase", "prefix": null, "suffix": null },
        "recordFieldNames": { "enabled": false },
        "enumCasesNames": { "enabled": true, "naming": "PascalCase", "prefix": null, "suffix": null },
        "unionCasesNames": { "enabled": true, "naming": "PascalCase", "prefix": null, "suffix": null },
        "moduleNames": { "enabled": true, "naming": "PascalCase", "prefix": null, "suffix": null },
        "literalNames": { "enabled": true, "naming": "PascalCase", "prefix": null, "suffix": null },
        "namespaceNames": { "enabled": true, "naming": "PascalCase", "prefix": null, "suffix": null },
        "memberNames": { "enabled": true, "naming": "PascalCase", "prefix": null, "suffix": null },
        "parameterNames": { "enabled": true, "naming": "camelCase", "prefix": null, "suffix": null },
        "measureTypeNames": { "enabled": true, "naming": "PascalCase", "prefix": null, "suffix": null },
        "activePatternNames": { "enabled": true, "naming": "PascalCase", "prefix": null, "suffix": null },
        "publicValuesNames": { "enabled": true, "naming": "PascalCase", "prefix": null, "suffix": null },
        "nonPublicValuesNames": { "enabled": true, "naming": "camelCase", "prefix": null, "suffix": null }
      }
    },
    "hints": {
      "enabled": false
    }
  }
}
