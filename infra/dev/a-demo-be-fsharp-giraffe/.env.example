# Demo Backend (FSGI — F#/Giraffe) Environment Variables
# Copy this file to .env and configure as needed

# PostgreSQL credentials for local dev
POSTGRES_USER=a_demo_be_fsharp_giraffe
POSTGRES_PASSWORD=a_demo_be_fsharp_giraffe

# JWT signing secret (min 32 chars for HS256 security)
APP_JWT_SECRET=change-me-in-dev-only-not-for-production

# Database URL for E2E tests (used by demo-be-e2e)
DATABASE_URL=Host=localhost;Port=5432;Database=a_demo_be_fsharp_giraffe;Username=a_demo_be_fsharp_giraffe;Password=a_demo_be_fsharp_giraffe
