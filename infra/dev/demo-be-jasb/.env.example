# Demo Backend (JASB) Environment Variables
# Copy this file to .env and configure as needed

# Spring Boot Profile (dev, staging, prod)
# - dev: Local Docker development with DevTools
# - staging: Kubernetes deployment for testing
# - prod: Kubernetes production deployment
SPRING_PROFILES_ACTIVE=dev

# JVM Options (production mode)
JAVA_OPTS=-Xms256m -Xmx512m -XX:+UseZGC

# Maven Options (development mode with docker-compose.override.yml)
MAVEN_OPTS=-Xmx512m

# PostgreSQL credentials for local dev
POSTGRES_USER=organiclever
POSTGRES_PASSWORD=organiclever

# JWT signing secret (min 32 chars for HS256 security)
APP_JWT_SECRET=change-me-in-production-use-a-real-random-secret

# Database URL for E2E tests (used by demo-be-e2e)
DATABASE_URL=postgresql://organiclever:organiclever@localhost:5432/demo_be
