# Development Docker Image for Demo Backend (JAVX — Java/Vert.x)
# Builds a fat JAR during image build so E2E mode starts instantly with `java -jar`.
# Dev mode still uses `mvn compile exec:java` with volume-mounted source.

FROM eclipse-temurin:25-jdk-alpine

# Install Maven and wget (for healthcheck)
RUN apk add --no-cache maven wget

WORKDIR /workspace

# Build fat JAR (shade plugin) to cache ALL Maven plugins/dependencies AND produce
# a runnable artifact. E2E override uses `java -jar /app/app.jar` for instant startup;
# dev mode still runs `mvn compile exec:java` against volume-mounted source.
COPY pom.xml /tmp/build/pom.xml
COPY src/ /tmp/build/src/
COPY generated-contracts/ /tmp/build/generated-contracts/
RUN cd /tmp/build \
    && mvn package -Dmaven.test.skip=true -Dmaven.antrun.skip=true -B \
    && mkdir -p /app \
    && cp /tmp/build/target/demo-be-java-vertx-1.0.0.jar /app/app.jar \
    && rm -rf /tmp/build

CMD ["mvn", "compile", "exec:java"]
