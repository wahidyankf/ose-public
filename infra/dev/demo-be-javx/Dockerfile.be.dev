# Development Docker Image for Demo Backend (JAVX — Java/Vert.x)
# Pre-downloads Maven dependencies AND pre-compiles source so container starts fast in CI.
# The app source is mounted via docker-compose volume at /workspace.

FROM eclipse-temurin:25-jdk-alpine

# Install Maven and wget (for healthcheck)
RUN apk add --no-cache maven wget

WORKDIR /workspace

# Copy pom.xml and source code, then compile to cache ALL Maven plugins and dependencies.
# dependency:resolve alone misses build-time plugins (compiler, exec, etc.) which causes
# 15+ minute cold downloads at container startup on CI.
COPY pom.xml /tmp/build/pom.xml
COPY src/ /tmp/build/src/
RUN cd /tmp/build && mvn compile exec:java -Dexec.skip=true -B 2>/dev/null; rm -rf /tmp/build

CMD ["mvn", "compile", "exec:java"]
