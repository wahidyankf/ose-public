{
  "name": "open-sharia-enterprise",
  "version": "1.0.0",
  "description": "Fintech application with monorepo architecture",
  "private": true,
  "workspaces": [
    "apps/*",
    "libs/*"
  ],
  "scripts": {
    "build": "nx run-many -t build",
    "test": "nx run-many -t test:quick",
    "lint": "nx run-many -t lint",
    "lint:md": "markdownlint-cli2 \"**/*.md\"",
    "lint:md:fix": "markdownlint-cli2 --fix \"**/*.md\"",
    "format:md": "prettier --write \"**/*.md\"",
    "format:md:check": "prettier --check \"**/*.md\"",
    "affected:build": "nx affected -t build",
    "affected:test": "nx affected -t test:quick",
    "affected:lint": "nx affected -t lint",
    "graph": "nx graph",
    "nx": "nx",
    "prepare": "husky",
    "postinstall": "npm run doctor || true",
    "demo-be:dev": "cd infra/dev/a-demo-be-java-springboot && docker compose up",
    "demo-be:dev:restart": "cd infra/dev/a-demo-be-java-springboot && docker compose down && docker compose up",
    "demo-be:clean": "sudo chown -R $USER:$USER apps/a-demo-be-java-springboot/target && rm -rf apps/a-demo-be-java-springboot/target",
    "organiclever:dev": "docker compose --env-file infra/dev/organiclever/.env -f infra/dev/organiclever/docker-compose.yml up --build",
    "organiclever:dev:restart": "docker compose --env-file infra/dev/organiclever/.env -f infra/dev/organiclever/docker-compose.yml down -v && docker compose --env-file infra/dev/organiclever/.env -f infra/dev/organiclever/docker-compose.yml up --build",
    "dev:a-demo-be-golang-gin": "docker compose -f infra/dev/a-demo-be-golang-gin/docker-compose.yml up --build",
    "dev:a-demo-be-java-springboot": "docker compose -f infra/dev/a-demo-be-java-springboot/docker-compose.yml up --build",
    "dev:a-demo-be-java-vertx": "docker compose -f infra/dev/a-demo-be-java-vertx/docker-compose.yml up --build",
    "dev:a-demo-be-elixir-phoenix": "docker compose -f infra/dev/a-demo-be-elixir-phoenix/docker-compose.yml up --build",
    "dev:a-demo-be-fsharp-giraffe": "docker compose -f infra/dev/a-demo-be-fsharp-giraffe/docker-compose.yml up --build",
    "dev:a-demo-be-csharp-aspnetcore": "docker compose -f infra/dev/a-demo-be-csharp-aspnetcore/docker-compose.yml up --build",
    "dev:a-demo-be-kotlin-ktor": "docker compose -f infra/dev/a-demo-be-kotlin-ktor/docker-compose.yml up --build",
    "dev:a-demo-be-python-fastapi": "docker compose -f infra/dev/a-demo-be-python-fastapi/docker-compose.yml up --build",
    "dev:a-demo-be-rust-axum": "docker compose -f infra/dev/a-demo-be-rust-axum/docker-compose.yml up --build",
    "dev:a-demo-be-ts-effect": "docker compose -f infra/dev/a-demo-be-ts-effect/docker-compose.yml up --build",
    "dev:a-demo-be-clojure-pedestal": "docker compose -f infra/dev/a-demo-be-clojure-pedestal/docker-compose.yml up --build",
    "dev:a-demo-fe-ts-nextjs": "docker compose -f infra/dev/a-demo-fe-ts-nextjs/docker-compose.yml up --build",
    "dev:a-demo-fe-ts-tanstack-start": "docker compose -f infra/dev/a-demo-fe-ts-tanstack-start/docker-compose.yml up --build",
    "dev:a-demo-fe-dart-flutterweb": "docker compose -f infra/dev/a-demo-fe-dart-flutterweb/docker-compose.yml up --build",
    "dev:a-demo-fs-ts-nextjs": "docker compose -f infra/dev/a-demo-fs-ts-nextjs/docker-compose.yml up --build",
    "dev:ayokoding-web": "docker compose -f infra/dev/ayokoding-web/docker-compose.yml up --build",
    "dev:oseplatform-web": "docker compose -f infra/dev/oseplatform-web/docker-compose.yml up --build",
    "dev:rhino-cli": "docker compose -f infra/dev/rhino-cli/docker-compose.yml up --build",
    "dev:ayokoding-cli": "docker compose -f infra/dev/ayokoding-cli/docker-compose.yml up --build",
    "dev:oseplatform-cli": "docker compose -f infra/dev/oseplatform-cli/docker-compose.yml up --build",
    "dev:organiclever": "docker compose --env-file infra/dev/organiclever/.env -f infra/dev/organiclever/docker-compose.yml up --build",
    "sync:claude-to-opencode": "nx run rhino-cli:build --skip-nx-cache && ./apps/rhino-cli/dist/rhino-cli agents sync",
    "sync:agents": "nx run rhino-cli:build --skip-nx-cache && ./apps/rhino-cli/dist/rhino-cli agents sync --agents-only",
    "sync:skills": "nx run rhino-cli:build --skip-nx-cache && ./apps/rhino-cli/dist/rhino-cli agents sync --skills-only",
    "sync:dry-run": "nx run rhino-cli:build --skip-nx-cache && ./apps/rhino-cli/dist/rhino-cli agents sync --dry-run",
    "validate:sync": "nx run rhino-cli:build --skip-nx-cache && ./apps/rhino-cli/dist/rhino-cli agents validate-sync",
    "validate:claude": "nx run rhino-cli:build --skip-nx-cache && ./apps/rhino-cli/dist/rhino-cli agents validate-claude",
    "validate:opencode": "npm run validate:sync",
    "validate:config": "npm run validate:claude && npm run sync:claude-to-opencode && npm run validate:opencode",
    "doctor": "nx run rhino-cli:build --skip-nx-cache && ./apps/rhino-cli/dist/rhino-cli doctor"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "type": "commonjs",
  "volta": {
    "node": "24.13.1",
    "npm": "11.10.1"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.1.0",
    "@commitlint/config-conventional": "^20.0.0",
    "@hey-api/client-fetch": "^0.13.1",
    "@hey-api/openapi-ts": "^0.94.2",
    "@openapitools/openapi-generator-cli": "^2.30.2",
    "@redocly/cli": "^2.22.1",
    "@stoplight/spectral-cli": "^6.15.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.6",
    "markdownlint-cli2": "^0.21.0",
    "nx": "22.5.2",
    "prettier": "^3.6.2",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tsx": "^4.20.6"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs,cjs}": "prettier --write",
    "*.json": "prettier --write",
    "*.go": "gofmt -w",
    "*.fs": "fantomas",
    "*.{ex,exs}": "scripts/format-elixir.sh",
    "*.py": "ruff format",
    "*.rs": "rustfmt",
    "*.cs": "scripts/format-csharp.sh",
    "*.clj": "scripts/format-clojure.sh",
    "*.dart": "scripts/format-dart.sh",
    "*.md": "prettier --write",
    "*.{yml,yaml}": "prettier --write",
    "*.{css,scss}": "prettier --write"
  },
  "dependencies": {
    "tailwindcss": "^4.2.1"
  }
}
